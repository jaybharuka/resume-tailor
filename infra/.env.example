# Path to the sibling hiring-agent-imp repo, relative to this infra/ directory
# (or an absolute path). The default below is correct for a normal checkout
# where resume-tailor/ and hiring-agent-imp/ are sibling directories. Override
# this if your checkout has a different layout (e.g. a git worktree nested
# inside resume-tailor/, where the default relative path won't resolve).
HIRING_AGENT_IMP_PATH=../../hiring-agent-imp
GEMINI_API_KEY=
NVIDIA_API_KEY=
